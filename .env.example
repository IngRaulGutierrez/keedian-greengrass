# ============================================================
# Credenciales AWS (usuario IAM con permisos IoT + Greengrass)
# ============================================================
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-2

# ============================================================
# Configuración del dispositivo
# ============================================================
DEVICE_NAME=NombreDispositivo
THING_NAME=GreengrassDockerCore

# ============================================================
# Endpoints de AWS IoT (se configuran automáticamente con setup.sh)
# ============================================================
IOT_DATA_ENDPOINT=
IOT_CRED_ENDPOINT=

# ============================================================
# Integración con keedian-link
# Ruta absoluta a la carpeta components/ del proyecto keedian-link.
# Si se deja vacío, setup.sh intenta detectarla automáticamente
# asumiendo que ambos proyectos están en el mismo directorio padre.
# Ejemplo: /home/user/projects/keedian-link/components
# ============================================================
KEEDIAN_LINK_COMPONENTS_PATH=

# ============================================================
# Componentes opcionales
# ============================================================
ENABLE_HELLO_WORLD=false
